# ============================================================
# 2. ZEITEXPANDIERTES NETZWERK ERZEUGEN
# ============================================================

def generate_time_arcs(
    hubs,
    hubs_by_id,
    arc_templates,
    mode_factors,
    shipment_weight,
    max_hour,
    hours_per_day=24,
):
    time_arcs = []
    planning_days = range((max_hour + hours_per_day - 1) // hours_per_day)

    # Transport-Arcs
    for template in arc_templates:
        from_hub = template["from"]
        to_hub = template["to"]
        mode = template["mode"]
        dist = template["dist"]

        duration = int(np.ceil(dist / mode_factors[mode]["speed_kmh"]))

        for day in planning_days:
            for dep_h in template["departure_hours"]:
                start_h = day * hours_per_day + dep_h
                arrival_h = start_h + duration

                if arrival_h <= max_hour:
                    time_arcs.append(
                        {
                            "service_id": template["id"],
                            "from": f"{from_hub}_{mode}_{start_h}",
                            "to": f"{to_hub}_{mode}_{arrival_h}",
                            "type": "transport",
                            "mode": mode,
                            "cost": dist * mode_factors[mode]["cost_per_ton_km"] * shipment_weight,
                            "emissions": dist * mode_factors[mode]["emissions_kg_per_ton_km"] * shipment_weight,
                            "duration": duration,
                            "departure_h": start_h,
                            "arrival_h": arrival_h,
                        }
                    )

    # Waiting-Arcs
    for hub in hubs:
        for mode in sorted(hub["supported_modes"]):
            for t in range(max_hour):
                time_arcs.append(
                    {
                        "from": f"{hub['id']}_{mode}_{t}",
                        "to": f"{hub['id']}_{mode}_{t + 1}",
                        "type": "waiting",
                        "mode": mode,
                        "cost": 5.0 * shipment_weight,
                        "emissions": 0.0,
                        "duration": 1,
                    }
                )

    # Transfer-Arcs
    for hub in hubs:
        windows = hub.get("transfer_windows", {})

        for (m1, m2), start_times in windows.items():
            for day in planning_days:
                for st in start_times:
                    t = day * hours_per_day + st

                    if t + 2 <= max_hour:
                        time_arcs.append(
                            {
                                "from": f"{hub['id']}_{m1}_{t}",
                                "to": f"{hub['id']}_{m2}_{t + 2}",
                                "type": "transfer",
                                "mode": f"{m1}->{m2}",
                                "cost": 50.0 * shipment_weight,
                                "emissions": 5.0 * shipment_weight,
                                "duration": 2,
                            }
                        )

    return time_arcs


# ============================================================
# 3. HEURISTIK-SOLVER
# ============================================================

class HeuristicRoutingSolver:
    def __init__(
        self,
        time_arcs,
        start_hub,
        end_hub,
        start_time,
        deadline,
        max_price,
        weights,
        normalizers,
    ):
        self.time_arcs = time_arcs
        self.start_hub = start_hub
        self.end_hub = end_hub
        self.start_time = start_time
        self.deadline = deadline
        self.max_price = max_price
        self.weights = weights
        self.normalizers = normalizers

        self.outgoing = defaultdict(list)

        for arc in time_arcs:
            self.outgoing[arc["from"]].append(arc)

    def get_hub(self, node):
        return node.split("_")[0]

    def get_time(self, node):
        return int(node.rsplit("_", 1)[-1])

    def arc_score(self, arc):
        return (
            self.weights["cost"] * (arc["cost"] / self.normalizers["cost"])
            + self.weights["time"] * (arc["duration"] / self.normalizers["time"])
            + self.weights["eco"] * (arc["emissions"] / self.normalizers["eco"])
        )

    def solve(self):
        start_nodes = [
            node
            for node in self.outgoing
            if self.get_hub(node) == self.start_hub
            and self.get_time(node) == self.start_time
        ]

        if not start_nodes:
            return {
                "status": "infeasible",
                "message": "Kein Startknoten gefunden.",
                "path": [],
            }

        pq = []
        best_score = {}

        for node in start_nodes:
            heapq.heappush(
                pq,
                (
                    0.0,
                    0.0,
                    0.0,
                    node,
                    [],
                ),
            )

        while pq:
            score_so_far, cost_so_far, eco_so_far, current_node, path = heapq.heappop(pq)

            current_hub = self.get_hub(current_node)
            current_time = self.get_time(current_node)

            if current_hub == self.end_hub and current_time <= self.deadline:
                return {
                    "status": "feasible",
                    "path": path,
                    "score": score_so_far,
                    "cost": cost_so_far,
                    "emissions": eco_so_far,
                    "arrival_time": current_time,
                    "duration": current_time - self.start_time,
                }

            for arc in self.outgoing.get(current_node, []):
                next_node = arc["to"]
                next_time = self.get_time(next_node)

                if next_time > self.deadline:
                    continue

                new_cost = cost_so_far + arc["cost"]

                if new_cost > self.max_price:
                    continue

                new_eco = eco_so_far + arc["emissions"]
                new_score = score_so_far + self.arc_score(arc)

                state = (next_node, round(new_cost, 2))

                if state not in best_score or new_score < best_score[state]:
                    best_score[state] = new_score

                    heapq.heappush(
                        pq,
                        (
                            new_score,
                            new_cost,
                            new_eco,
                            next_node,
                            path + [arc],
                        ),
                    )

        return {
            "status": "infeasible",
            "message": "Keine zulässige Route gefunden.",
            "path": [],
        }


