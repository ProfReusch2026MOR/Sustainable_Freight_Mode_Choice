# 4. AUSGABE
# ============================================================

def print_solution(result):
    if result["status"] != "feasible":
        print(result.get("message", "Keine Lösung gefunden."))
        return

    print("\nHeuristische Route gefunden:\n")

    for arc in result["path"]:
        print(
            f"[{arc['from']}] -> [{arc['to']}] | "
            f"Modus: {arc['mode']:10} | "
            f"Typ: {arc['type']:10} | "
            f"Kosten: {arc['cost']:8.2f} | "
            f"CO2: {arc['emissions']:8.2f}"
        )

    print("\n" + "=" * 40)
    print(f"Score:         {result['score']:10.4f}")
    print(f"Kosten:        {result['cost']:10.2f} EUR")
    print(f"CO2:           {result['emissions']:10.2f} kg")
    print(f"Ankunft:       {result['arrival_time']:10d} h")
    print(f"Dauer:         {result['duration']:10d} h")
    print("=" * 40)


