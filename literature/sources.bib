@article{SCHRIMPF2000139,
  title = {Record Breaking Optimization Results Using the Ruin and Recreate Principle},
  journal = {Journal of Computational Physics},
  volume = {159},
  number = {2},
  pages = {139-171},
  year = {2000},
  issn = {0021-9991},
  doi = {https://doi.org/10.1006/jcph.1999.6413},
  url = {https://www.sciencedirect.com/science/article/pii/S0021999199964136},
  author = {Gerhard Schrimpf and Johannes Schneider and Hermann Stamm-Wilbrandt and Gunter Dueck},
  abstract = {A new optimization principle is presented. Solutions of problems are partly, but significantly, ruined and rebuilt or recreated afterwards. Performing this type of change frequently, one can obtain astounding results for classical optimization problems. The new method is particularly suited for more complex optimization problems (“discontinuous” ones, problems with hard-to-find admissible solutions, problems with complex objectives or many constraints). The method is an all-purpose-heuristic. Numerical results are given for the Traveling Salesman Problem, for the Vehicle Routing Problem with time windows, and for network optimization. Numerical evidence for the quality of the proposed principle is given. For most of the instances of a research library of problems, the ruin and recreate (R&R) implementation achieved the best published results. For many instances, better or much better solutions could be found.}
}

