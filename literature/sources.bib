@article{bryan1999hub,
  author    = {Bryan, Deborah L. and O'Kelly, Morton E.},
  title     = {Hub-and-Spoke Networks in Air Transportation: An Analytical Review},
  journal   = {Journal of Regional Science},
  volume    = {39},
  number    = {2},
  pages     = {275-295},
  doi       = {https://doi.org/10.1111/1467-9787.00134},
  url       = {https://onlinelibrary.wiley.com/doi/abs/10.1111/1467-9787.00134},
  eprint    = {https://onlinelibrary.wiley.com/doi/pdf/10.1111/1467-9787.00134},
  abstract  = {In this review we survey advances in analysis of the hub location problem and its variants. In the course of the review opportunities for enhanced analysis become apparent. We emphasize the most pressing areas for further work. We found that first, research needs to be devoted to developing more reliable heuristics for the multiple assignment model and its extensions and second, that additional research is needed to understand the conditions under which the model will tend to have integer solutions. Research in this area will contribute to the solution of a longstanding puzzle in economics about the allocation of indivisible resources.},
  year      = {1999}
}

